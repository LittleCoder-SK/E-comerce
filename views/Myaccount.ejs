<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>my account</title>
    <link rel="stylesheet" href="/stylesheet/account.css">
</head>

<body>

    <div class="user-account">

        <div class="account">
            <h2>My Account</h2>
            <% if (user) { %>
                <div class="account-card">
                    <h4>Personal Information</h4>
                    <div class="info">
                        <p>Name: <%= user.fullname %>
                        </p>
                        <p>Email: <%= user.email %>
                        </p>
                    </div>
                </div>
                <% } %>
                    <div class="out">
                        <img src="/images/right-from-bracket-solid.png" alt="out" class="logout"><a
                            href="/users/logout">Logout</a>
                    </div>
        </div>

        <div class="products">
            <div class="header">
                <h2>Products created by, <%= user.fullname %>
                </h2>
            </div>
            <div class="all-product">
                <!-- product card -->
                <% products.forEach( product=> { %>
                    <div class="product-card">
                        <div class="image">
                            <img src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
                                alt="product-image">
                            <div class="edit">
                                <form action="/myaccount/edit/<%= product._id %>" method="GET">
                                    <button type="submit">Edit</button>
                                </form>
                            </div>
                            <div class="delete">
                                <form action="/myaccount/delete/<%= product._id %>">
                                    <button type="submit">Delete</button>
                                </form>
                            </div>
                        </div>
                        <div class="product-detail">
                            <p>
                                <%= product.name %>
                            </p>
                            <p> ₹<span>
                                    <%= product.price %>
                                </span></p>
                        </div>
                    </div>
                    <% }) %>
            </div>

        </div>
</body>

</html>